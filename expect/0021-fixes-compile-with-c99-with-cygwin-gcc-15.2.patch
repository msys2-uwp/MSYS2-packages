 EXTERN int exp_configure_count;	/* # of times descriptors have been closed */
@@ -321,7 +321,7 @@ EXTERN void		exp_init_expect_cmds _ANSI_ARGS_((Tcl_Interp *));
 EXTERN void		exp_init_most_cmds _ANSI_ARGS_((Tcl_Interp *));
