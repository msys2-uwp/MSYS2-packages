pkgname=expect
pkgver=5.45.4
pkgrel=7
pkgdesc="A tool for automating interactive applications"
arch=('i686' 'x86_64')
url="https://www.nist.gov/el/msid/expect.cfm"
msys2_references=(
  "cpe: cpe:/a:don_libes:expect"
)
license=('custom')
depends=('tcl')
makedepends=('autotools' 'gcc' 'tcl-devel')

patches=(
  # patches from https://src.fedoraproject.org/rpms/enscript/blob/rawhide/f/enscript.spec
  # Use regexp 'Patch\d+: ' to replace prefixes

  # Patch0: fixes change log file permissions
  expect-5.43.0-log_file.patch
  # Patch1: fixes install location, change pkgIndex
  # NOTE: cygwin do not need the pkgpath fixes
  # expect-5.43.0-pkgpath.patch
  # Patch2: fixes minor man page formatting issue
  expect-5.45-man-page.patch
  # Patch3: fixes segmentation fault during matching characters
  expect-5.45-match-gt-numchars-segfault.patch
  # Patch4: fixes memory leak when using -re, http://sourceforge.net/p/expect/patches/13/
  expect-5.45-re-memleak.patch
  # Patch5: use vsnprintf instead of vsprintf to avoid buffer overflow
  expect-5.45-exp-log-buf-overflow.patch
  # Patch6: fixes segfaults if Tcl is built with stubs and Expect is used directly
  #   from C program rhbz#1091060
  expect-5.45-segfault-with-stubs.patch
  # Patch7: fixes leaked fd, patch by Matej Mu?ila, rhbz#1001220
  expect-5.45-fd-leak.patch
  # Patch8: unificates usage message of expect binary and man page, adds -h flag
  expect-5.45.4-unification-of-usage-and-man-page.patch
  # Patch9: fixes issues detected by static analysis
  expect-5.45.4-covscan-fixes.patch
  # examples patches
  # Patch100: changes random function
  expect-5.32.2-random.patch
  # Patch101: fixes bz674184 - mkpasswd fails randomly
  expect-5.45-mkpasswd-dash.patch
  # Patch102: fixes bz703702 - let user know that telnet is needed for
  # running some examples
  expect-5.45-check-telnet.patch
  # Patch103: use full path to 'su', it's safer
  expect-5.45-passmass-su-full-path.patch
  # Patch104: rhbz 963889, fixes inaccuracy in mkpasswd man page
  expect-5.45-mkpasswd-man.patch
  # Patch105: Fix error with -Werror=format-security
  expect-5.45-format-security.patch
  expect-configure-c99.patch
  expect-c99.patch
  # Patch108: fix tclsh path for 'example' binaries (tcl8 compat package has no 'tclsh')
  expect-5.45.4-tclsh8.patch


  # Fixes for cygwin
  5.45-openpty.patch
  0021-fixes-compile-with-c99-with-cygwin-gcc-15.2.patch
)

source=(https://sourceforge.net/projects/expect/files/Expect/${pkgver}/expect${pkgver}.tar.gz)
source+=(${patches[@]})

