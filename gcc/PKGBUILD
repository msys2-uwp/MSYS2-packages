# Helper macros to help make tasks easier #
apply_patch_with_msg() {
  for _fname in "$@"
  do
    msg2 "Applying ${_fname}"
    patch -Nbp1 -i "${srcdir}"/${_fname}
  done
}

del_file_exists() {
  for _fname in "$@"
  do
    if [ -f $_fname ] || [ -d $_fname ]; then
      rm -rf $_fname
    fi
  done
}
# =========================================== #

currnent_script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)
source "${currnent_script_dir}/../msys2-runtime/check-bootstrap.sh"

prepare() {
  cd ${srcdir}/gcc-${pkgver}

  # Remove files created by patches
  rm -f libgomp/config/cygwin/plugin-suffix.h \
    > /dev/null 2>&1

  # Cygwin patches
  apply_patch_with_msg \
    0001-Always-define-WIN32_LEAN_AND_MEAN-before-windows.h.patch \
    0002-add-m-no-align-vector-insn-option-for-i386.patch \
    0003-Cygwin-use-SysV-ABI-on-x86_64.patch \
    0004-Cygwin-add-dummy-pthread-tsaware-and-large-address-a.patch \
    0005-Cygwin-handle-dllimport-properly-in-medium-model-V2.patch \
    0006-Cygwin-fix-some-implicit-declaration-warnings-and-re.patch \
    0007-Cygwin-define-RTS_CONTROL_ENABLE-and-DTR_CONTROL_ENA.patch \
    0008-Cygwin-__cxa-atexit.patch \
    0009-Cygwin-libgomp-soname.patch \
    0010-Cygwin-g-time.patch \
    0011-Cygwin-newlib-ftm.patch \
    0012-Cygwin-define-STD_UNIX.patch \
    0013-Cygwin-enable-libgccjit-not-just-for-MingW.patch \
    0014-Cygwin-testsuite-fixes-for-libgccjit.patch \
    0017-fix-build-pretty-print.patch \
    0018-fix-build-opts.patch \
    0019-builtin_define-MSYS-and-update-t-cygwin-w64.patch

  if [[ "$MSYS_BOOTSTRAP_STAGE" == "stage0" ]]; then
    apply_patch_with_msg \
      0020-gcc_libs-linkage-to-_msys_dll_entry.patch
  fi

  # Skipped Cygwin patches
  #
  # Would need a dependency on libiconv and libintl development files, see
  # https://github.com/msys2/MSYS2-packages/pull/5458#issuecomment-3008811572
  # https://cygwin.com/pipermail/cygwin-apps/2025-May/044326.html
  # 0015-libstdc-Implement-most-of-locale-features-for-newlib.patch
  # 0016-fix-build-stage1-now-depends-on-libintl-libiconv.patch


  # Do not run fixincludes
  #sed -i 's@\./fixinc\.sh@-c true@' gcc/Makefile.in
  echo ${pkgver} > gcc/BASE-VER
  # hack! - some configure tests for header files using "$CPP $CPPFLAGS"
  sed -i "/ac_cpp=/s/\$CPPFLAGS/\$CPPFLAGS -O2/" {libiberty,gcc}/configure

  pushd ${srcdir}/gcc-${pkgver}/lto-plugin
  WANT_AUTOCONF="2.69" autoreconf --force

  pushd ${srcdir}/gcc-${pkgver}/libcpp
  WANT_AUTOCONF="2.69" autoreconf --force

  pushd ${srcdir}/gcc-${pkgver}/libatomic
  WANT_AUTOCONF="2.69" autoreconf --force

  pushd ${srcdir}/gcc-${pkgver}/libgcc
  WANT_AUTOCONF="2.69" autoreconf --force

  pushd ${srcdir}/gcc-${pkgver}/libgomp
  WANT_AUTOCONF="2.69" autoreconf --force

  pushd ${srcdir}/gcc-${pkgver}/libquadmath
  WANT_AUTOCONF="2.69" autoreconf --force

  pushd ${srcdir}/gcc-${pkgver}/libstdc++-v3
  WANT_AUTOCONF="2.69" autoreconf --force

  pushd ${srcdir}/gcc-${pkgver}/
  WANT_AUTOCONF="2.69" autoreconf --force
}

build() {
  rm -rf ${srcdir}/build-MSYS
  mkdir -p ${srcdir}/build-MSYS && cd ${srcdir}/build-MSYS

  case ${CARCH} in
    i686)
      _arch=pentium4
      _arch_conf="--disable-sjlj-exceptions"
    ;;
    x86_64)
      _arch=nocona
      _arch_conf=
    ;;
  esac

  # libgcc is built with -g0, but INHIBIT_LIBC_CFLAGS can
  # be used to undo that.
  if check_option "debug" "y"; then
    export INHIBIT_LIBC_CFLAGS="-g2"
  fi

  # using -pipe causes spurious test-suite failures
  # https://gcc.gnu.org/bugzilla/show_bug.cgi?id=48565
  CFLAGS=${CFLAGS/-pipe/}
  CXXFLAGS=${CXXFLAGS/-pipe/}

  export lt_cv_deplibs_check_method='pass_all'
  enable_bootstrap="--enable-bootstrap"
  if [[ "$MSYS_BOOTSTRAP_STAGE" == "stage3" ]]; then
    # stage3 gcc linkage to cygwin, gcc-libs linkage to cygwin without hack
    enable_bootstrap="--enable-bootstrap"
  elif [[ "$MSYS_BOOTSTRAP_STAGE" == "stage2" ]]; then
    # stage2 gcc linkage to cygwin, gcc-libs linkage to cygwin without hack
    enable_bootstrap="--enable-bootstrap"
  elif [[ "$MSYS_BOOTSTRAP_STAGE" == "stage1" ]]; then
    # stage1 gcc linkage to cygwin, gcc-libs use the one comes from stage1 that linkage to cygwin
    enable_bootstrap="--disable-bootstrap"
  elif [[ "$MSYS_BOOTSTRAP_STAGE" == "stage0" ]]; then
    # stage0 gcc linkage to msys, gcc-libs linkage to cygwin
    enable_bootstrap="--disable-bootstrap"
  else
    echo "Invalid stage $MSYS_BOOTSTRAP_STAGE for enable_bootstrap"
    exit -1
  fi
  export MSYSTEM=CYGWIN

  ${srcdir}/gcc-${pkgver}/configure \
    --build=${CHOST} \
    --prefix=/usr \
    --libexecdir=/usr/lib \
    ${enable_bootstrap} \
    --enable-static \
    --enable-shared \
    --enable-shared-libgcc \
    --enable-version-specific-runtime-libs \
    --with-arch=${_arch} \
    --with-tune=generic \
    --disable-multilib \
    ${_arch_conf} \
    --enable-__cxa_atexit \
    --with-dwarf2 \
    --enable-languages=c,c++,lto \
    --enable-graphite \
    --enable-threads=posix \
    --enable-libatomic \
    --enable-libgomp \
    --disable-libitm \
    --enable-libquadmath \
    --enable-libquadmath-support \
    --disable-libssp \
    --disable-win32-registry \
    --disable-symvers \
    --with-gnu-ld \
    --with-gnu-as \
    --disable-isl-version-check \
    --enable-checking=release \
    --without-libiconv-prefix \
    --without-libintl-prefix \
    --with-system-zlib \
    --enable-linker-build-id \
    --enable-libstdcxx-filesystem-ts
  if [[ "$MSYS_BOOTSTRAP_STAGE" == "stage3" ]]; then
    # stage3 gcc linkage to cygwin, gcc-libs linkage to cygwin without hack
    make
  elif [[ "$MSYS_BOOTSTRAP_STAGE" == "stage2" ]]; then
    # stage2 gcc linkage to cygwin, gcc-libs linkage to cygwin without hack
    make
  elif [[ "$MSYS_BOOTSTRAP_STAGE" == "stage1" ]]; then
    # stage1 gcc linkage to cygwin, do not build gcc-libs
    make all-host
    rm -rf ${srcdir}/dest-install
    DESTDIR=${srcdir}/dest-install \
    make -j1 install-host

    MSYS_IN_PKGBUILD=enabled srcdir=${srcdir} DESTDIR=${srcdir}/dest-install \
    sh ${pkg_root_dir}/build-install/gcc-prepare.sh

  elif [[ "$MSYS_BOOTSTRAP_STAGE" == "stage0" ]]; then
    # stage0 gcc linkage to msys, gcc-libs linkage to cygwin

    # First getting gcc/gcc-libs linkage to msys
    make

    # Then getting gcc-libs linkage to cygwin
    cd ${srcdir}/gcc-${pkgver}

    apply_patch_with_msg \
      0021-gcc_libs-linkage-to-_cygwin_dll_entry.patch

    cd ${srcdir}/gcc-${pkgver}/libatomic
    WANT_AUTOCONF="2.69" autoreconf --force

    cd ${srcdir}/gcc-${pkgver}/libgcc
    WANT_AUTOCONF="2.69" autoreconf --force

    cd ${srcdir}/gcc-${pkgver}/libgomp
    WANT_AUTOCONF="2.69" autoreconf --force

    cd ${srcdir}/gcc-${pkgver}/libquadmath
    WANT_AUTOCONF="2.69" autoreconf --force

    cd ${srcdir}/gcc-${pkgver}/libstdc++-v3
    WANT_AUTOCONF="2.69" autoreconf --force

    echo "Rebuilding the gcc-libs"

    # Gcc libs linkage cygwin dll
    MSYS_IN_PKGBUILD=enabled srcdir=${srcdir} DESTDIR=${srcdir}/dest-install \
    sh ${pkg_root_dir}/build-install/gcc-prepare.sh

    cd ${srcdir}/build-MSYS
    export PATH=${srcdir}/build-MSYS/x86_64-pc-cygwin/libgcc/shlib:$PATH
    rm -rf x86_64-pc-cygwin
    make
  else
    echo "Invalid stage $MSYS_BOOTSTRAP_STAGE"
    exit -1
  fi

  # make documentation
  #cd $CHOST/libstdc++-v3
  #make doc-man-doxygen
}

