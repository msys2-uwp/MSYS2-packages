# Maintainer: Alexey Pavlov <Alexpux@gmail.com>

pkgname=('mpfr' 'mpfr-devel')
_pkgver=4.2.2
pkgver=${_pkgver}
# pkgver=${_pkgver}.p1
pkgrel=2
pkgdesc="Multiple-precision floating-point library"
arch=('i686' 'x86_64')
url="https://www.mpfr.org/"
msys2_repository_url='https://gitlab.inria.fr/mpfr/mpfr'
msys2_references=(
  "cpe: cpe:/a:mpfr:gnu_mpfr"
)
license=('spdx:LGPL-3.0-or-later')
depends=('gmp>=5.0')
makedepends=('gmp-devel>=5.0' 'autotools' 'gcc' 'autoconf-archive')
source=(https://www.mpfr.org/mpfr-current/mpfr-${_pkgver}.tar.xz{,.asc}
        0001-Linkage-to-_cygwin_dll_entry-for-libmpfr.patch)
        # patches.patch)
# wget https://www.mpfr.org/mpfr-4.2.1/allpatches -O patches.patch
validpgpkeys=('A534BE3F83E241D918280AEB5831D11A0D4DB02A') # Vincent Lefevre <vincent@vinc17.net>
sha256sums=('b67ba0383ef7e8a8563734e2e889ef5ec3c3b898a01d00fa0a6869ad81c6ce01'
            'SKIP'
            '7e797ce5b2902d3943389555e90c53af92bb7395938cc6172041728534b69f0e')

prepare() {
  cd "${srcdir}/${pkgname}-${_pkgver}"

  patch -p1 -i ${srcdir}/0001-Linkage-to-_cygwin_dll_entry-for-libmpfr.patch

  autoreconf -fi
}

build() {
  cd "${srcdir}/${pkgname}-${_pkgver}"

  ./configure --build=${CHOST} \
    --prefix=/usr \
    --enable-shared \
    --disable-static
  make
  make DESTDIR="${srcdir}/dest" install
}

check() {
  cd "${srcdir}/${pkgname}-${_pkgver}"
  make check
}

package_mpfr() {
  groups=('libraries')

  mkdir -p ${pkgdir}/usr

  cp -rf ${srcdir}/dest/usr/bin ${pkgdir}/usr/
  cp -rf ${srcdir}/dest/usr/share ${pkgdir}/usr/
}

package_mpfr-devel() {
  groups=('development')
  options=('staticlibs')
  depends=("mpfr=${pkgver}" 'gmp-devel')
  pkgdesc="MPFR headers and libraries"

  mkdir -p ${pkgdir}/usr
  cp -rf ${srcdir}/dest/usr/include ${pkgdir}/usr/
  cp -rf ${srcdir}/dest/usr/lib ${pkgdir}/usr/
}
